# Remote (online) TTS configuration (OpenAI-compatible)
#
# Copy to `.env` and fill in real values. `.env` is ignored by git.

FUDOKI_TTS_OPENAI_BASE_URL=https://one-dev.felo.me/v1
FUDOKI_TTS_OPENAI_API_KEY=your_api_key_here

# Recommended default for this app's one-shot `/audio/speech` path:
# - gpt-4o-mini-tts: OpenAI's dedicated speech-generation model
#
# Other OpenAI audio-capable models you can try if your compatible gateway supports them:
# - gpt-audio-1.5
# - gpt-realtime-1.5
# - gpt-realtime-mini
# - tts-1
# - tts-1-hd
FUDOKI_TTS_OPENAI_MODEL=gpt-4o-mini-tts
FUDOKI_TTS_OPENAI_MODEL_OPTIONS=gpt-4o-mini-tts,gpt-audio-1.5,gpt-realtime-1.5
FUDOKI_TTS_OPENAI_VOICE=alloy
FUDOKI_TTS_OPENAI_VOICE_OPTIONS=marin,cedar,alloy
FUDOKI_TTS_OPENAI_FORMAT=mp3

# Which provider to use by default if no UI selection is stored.
FUDOKI_TTS_DEFAULT_PROVIDER=openai-compatible
